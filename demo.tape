# vhs demo tape — generates demo.gif
# Regenerate: vhs demo.tape  (requires Ollama running with qwen2.5:7b warm)

Output demo.gif

Set FontSize 16
Set Width 1100
Set Height 560
Set Theme "Dracula"
Set Padding 18
Set TypingSpeed 45ms

Sleep 600ms
Type "./run --route FAST 'name three real-world uses of a hash map'"
Sleep 600ms
Enter
Sleep 20s
Sleep 2s
