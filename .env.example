# ============================================================
# agents — environment variables
# Copy this to .env and fill in your values:  cp .env.example .env
# ============================================================

# --- Required (for CLAUDE node) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Ollama ---
OLLAMA_API_BASE=http://localhost:11434

# --- Model overrides (optional — defaults set in config.yaml) ---
# Uncomment to override config.yaml values. Env vars always take precedence.
# ORCHESTRATOR_MODEL=ollama/qwen3:32b
# CODER_MODEL=ollama/qwen2.5-coder:32b
# RESEARCHER_MODEL=ollama/deepseek-r1:14b
# FAST_MODEL=ollama/qwen2.5:7b
# CLAUDE_MODEL=claude-sonnet-4-6
